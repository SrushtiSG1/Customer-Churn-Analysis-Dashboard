      <aliases enabled='yes' />
      <column caption='Tenure Group' datatype='string' name='[Calculation_0670762498101250]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF  [tenure] &lt;= 12 THEN &quot;0-1 Year&quot;&#13;&#10;ELSEIF [tenure] &lt;= 24 THEN &quot;1-2 Years&quot;&#13;&#10;ELSEIF [tenure] &lt;= 48 THEN &quot;2-4 Years&quot;&#13;&#10;ELSE &quot;4+ Years&quot;&#13;&#10;END' />
      </column>
      <column caption='Churn Flag' datatype='integer' name='[Calculation_0670762501832709]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [Churn] = &quot;Yes&quot; THEN 1 ELSE 0 END' />
      </column>
      <column caption='Churn Rate' datatype='real' name='[Calculation_0670762503720966]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Calculation_0670762501832709])/COUNT([customerID])' />
      </column>
      <column caption='Total Customers' datatype='integer' name='[Calculation_0717492280602624]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD([customerID])' />
      </column>
      <column caption='Avg Revenue' datatype='real' name='[Calculation_0717492281040897]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG([MonthlyCharges])' />
      </column>
      <column caption='CalPara' datatype='real' name='[Calculation_0717492281229314]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='CASE [Parameters].[Parameter 1]&#13;&#10;WHEN &quot;Churn Rate&quot; THEN SUM([Calculation_0670762501832709]) / COUNT([customerID])&#13;&#10;WHEN &quot;Avg Revenue&quot; THEN AVG([MonthlyCharges])&#13;&#10;WHEN &quot;Total Customers&quot; THEN COUNT([customerID])&#13;&#10;END' />
      </column>
